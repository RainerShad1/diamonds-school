generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoSolicitud {
  PENDIENTE
  EN_REVISION
  APROBADA
  RECHAZADA
}

model Solicitud {
  id               String          @id @default(cuid())
  codigo           String          @unique
  nombreEstudiante String
  fechaNacimiento  String
  nivel            String
  nombreTutor      String
  telefono         String
  email            String
  mensaje          String?
  estado           EstadoSolicitud @default(PENDIENTE)
  observaciones    String?
  creadaEn         DateTime        @default(now())
}

model ImagenGaleria {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  imagen      String
  creadaEn    DateTime @default(now())
}

model Publicacion {
  id        String   @id @default(cuid())
  titulo    String
  contenido String
  creadaEn  DateTime @default(now())
}
